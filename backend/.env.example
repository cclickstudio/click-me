# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# Database (NeonDB / PostgreSQL + pgvector)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# ──────────────────────────────────────────────
# LLM — OpenAI
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────
# LLM — Anthropic
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# LLM — Google Gemini (채팅 어드바이저)
# ──────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ──────────────────────────────────────────────
# LangSmith (AI 파이프라인 트레이싱)
# ──────────────────────────────────────────────
LANGSMITH_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=clickme-v2

# ──────────────────────────────────────────────
# AWS
# ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2

# S3
S3_BUCKET_NAME=clickme-assets

# SQS
SQS_SIMULATION_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/...
SQS_MAX_WORKERS=10

# ──────────────────────────────────────────────
# Simulation
# ──────────────────────────────────────────────
DEFAULT_PERSONA_COUNT=20
MAX_PERSONA_COUNT=1000

# ──────────────────────────────────────────────
# Meta / Instagram Content Publishing (Generator)
# 둘 다 비워두면 Mock 게시 모드로 동작
# ──────────────────────────────────────────────
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_GRAPH_API_VERSION=v21.0

# ──────────────────────────────────────────────
# Generator (광고 생성)
# ──────────────────────────────────────────────
GENERATOR_TEXT_MODEL=gpt-4o
GENERATOR_IMAGE_MODEL=gpt-image-1
GENERATOR_IMAGE_QUALITY=medium   # low | medium | high
